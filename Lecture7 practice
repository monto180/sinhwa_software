#백준 2153
import math

word = input()

a = 0

for i in word:
    if i.islower():
        a+= ord(i) -96
    else:
        a += ord(i) -38

isPrime = True
for j in range(2, int(math.sqrt(a)) +1):
    if a % j == 0:
        isPrime = False

if isPrime:
    print('It is a prime word.')
else:
    print('It is not a prime word.')

