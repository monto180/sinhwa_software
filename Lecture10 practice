M, N = map(int, input().split())
sosu = 0
array = []

for i in range(M, N+1):
    for j in range(2,i):
        if i % j == 0:
            sosu += 1
            break
    if sosu == 0 and i != 1:
        array.append(i)
    sosu = 0

if len(array) == 0:
    print(-1)
else:
    print(sum(array))
    print(min(array))
