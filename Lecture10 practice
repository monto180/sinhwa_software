def self_num(n):
    a = list(str(n))
    result = 0
    for i in range(len(a)):
        result +=int(a[i])
    result = result + n
    return result

results = set()
for j in range(10000):
    results.add(self_num(j))
for k in range(1,10001):
    if k not in results:
        print(k)

